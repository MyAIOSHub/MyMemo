# MyMemo — local backend configuration
# Copy to .env and fill in the required values.

# =============================================================================
# REQUIRED
# =============================================================================

# Fernet-safe encryption key for credentials stored in SurrealDB.
# Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Any stable passphrase works — it gets normalized via SHA-256.
OPEN_NOTEBOOK_ENCRYPTION_KEY=change-me-to-a-secret-string

# Password for the API bearer-token middleware.
# Default is insecure; override in any real deployment.
OPEN_NOTEBOOK_PASSWORD=open-notebook-change-me

# =============================================================================
# MEMORY HUB (port 1995)
# =============================================================================
# The API proxies /api/memories/* to the EverCore Memory Hub. If the hub is not
# running, memory endpoints degrade gracefully (/memories/status returns
# connected=false) and nothing else breaks.

MEMORY_HUB_URL=http://localhost:1995
MEMORY_HUB_USER_ID=mymemo_user

# =============================================================================
# SURREALDB (local store for Source snapshots + Credential records)
# =============================================================================

SURREAL_URL=ws://surrealdb:8000/rpc
SURREAL_USER=root
SURREAL_PASSWORD=root
SURREAL_NAMESPACE=mymemo
SURREAL_DATABASE=mymemo

# =============================================================================
# OPTIONAL — AI provider keys (env fallback; DB-stored credentials take priority)
# =============================================================================
# Configuring via the UI (/api/credentials) is preferred — keys are encrypted
# at rest and can be rotated without touching config files.

# OpenAI
# OPENAI_API_KEY=sk-...

# Anthropic
# ANTHROPIC_API_KEY=sk-ant-...

# Google AI
# GOOGLE_API_KEY=...

# Groq
# GROQ_API_KEY=gsk_...

# =============================================================================
# OPTIONAL — Advanced
# =============================================================================

# Ollama endpoint (local)
# OLLAMA_BASE_URL=http://ollama:11434

# Chunking overrides (defaults: 1500 / 225)
# CHUNK_SIZE=1500
# CHUNK_OVERLAP=225

LLM_PROVIDER=openai
LLM_MODEL=x-ai/grok-4-fast
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY=

GATEWAY_IMAGE=nginx:alpine
MONGODB_IMAGE=mongo:7.0
REDIS_IMAGE=redis:7.2-alpine
MILVUS_MINIO_IMAGE=minio/minio:RELEASE.2023-03-20T20-16-18Z
MILVUS_IMAGE=milvusdb/milvus:v2.5.2
NODE_BASE_IMAGE=node:20-bookworm-slim
UV_BASE_IMAGE=ghcr.io/astral-sh/uv:python3.12-bookworm-slim

VECTORIZE_PROVIDER=dashscope
VECTORIZE_API_KEY=
VECTORIZE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
VECTORIZE_MODEL=text-embedding-v4
VECTORIZE_FALLBACK_PROVIDER=none

RERANK_PROVIDER=dashscope
RERANK_API_KEY=
RERANK_BASE_URL=https://dashscope.aliyuncs.com/api/v1/services/rerank/text-rerank/text-rerank
RERANK_MODEL=qwen3-rerank
RERANK_FALLBACK_PROVIDER=none

BROWSER_SYNC_ENABLED=true
BROWSER_SYNC_LOCAL_STORE_BASE_URL=http://local-store:37651
BROWSER_SYNC_POLL_SECONDS=5
BROWSER_SYNC_CONVERSATION_STABLE_SECONDS=15
BROWSER_SYNC_SNIPPET_STABLE_SECONDS=3
BROWSER_SYNC_USER_ID=mymemo_user

CCHISTORY_SYNC_INTERVAL_SECONDS=300
CCHISTORY_SYNC_USER_ID=mymemo_user

# --- EverCore v1 (multi-tenant) ---
# Single-tenant mode: all data lives under this id in MongoDB / Milvus / Elasticsearch.
TENANT_SINGLE_TENANT_ID=t_mymemo
# Memorize mode: 'online' = LLM clusters memories synchronously; 'batch' = deferred.
AGENT_MEMORIZE_MODE=online
# Retrieval tuning (defaults match upstream env.template).
MILVUS_SIMILARITY_THRESHOLD=0.6
RECALL_MULTIPLIER=2
RERANK_SCORE_THRESHOLD=0.6
TOPK_LIMIT=100
